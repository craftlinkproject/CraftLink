{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://craftlink-production.up.railway.app/api/:path*" },
    { "source": "/socket.io/:path*", "destination": "https://craftlink-production.up.railway.app/socket.io/:path*" },
    { "source": "/((?!api|assets|.*\\..*).*)", "destination": "/frontend/index.html" }
  ]
}
