{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://craftlink-production.up.railway.app/api/$1" },
    { "source": "/socket.io/(.*)", "destination": "https://craftlink-production.up.railway.app/socket.io/$1" },
    { "source": "/((?!api|assets|.*\\..*).*)", "destination": "/frontend/index.html" }
  ]
}
